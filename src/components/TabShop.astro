---
import missing from '../data/missing.json';
import glazes from '../data/glazes.json';

const G = Object.fromEntries(glazes.map(g => [g.code, g]));

// Sort by most combos unlocked (descending)
const sorted = [...missing].sort((a, b) => b.combos.length - a.combos.length);

function dot(hex, size = 10) {
  return `<span style="display:inline-block;width:${size}px;height:${size}px;border-radius:50%;background:${hex};flex-shrink:0;border:0.5px solid rgba(0,0,0,.12)"></span>`;
}
---

<div id="tp-shop" class="tp">
  <div class="tip">Missing glazes ranked by how many new documented combinations they'd unlock with what you already own.</div>
  <div class="grid" id="shgrid">
    {sorted.map(m => (
      <div class="card">
        <div class="shop-hd">
          <div style={`width:30px;height:30px;border-radius:50%;background:${m.hex};border:0.5px solid rgba(0,0,0,.12);flex-shrink:0`}></div>
          <div>
            <div class="shop-nm">{m.code} {m.name}</div>
            <div class="shop-ct">Unlocks {m.combos.length} new combinations</div>
          </div>
        </div>
        <p style="font-size:12px;color:var(--text-2);margin:0 0 9px;line-height:1.55">{m.why}</p>
        <ul class="new-list">
          {m.combos.map(cb => {
            const bg = G[cb.base] ?? { hex: '#999' };
            const tg = G[cb.top]  ?? { hex: '#888' };
            return (
              <li>
                <Fragment set:html={dot(bg.hex, 7)} />
                {cb.base}
                <span style="color:var(--text-3);margin:0 3px">→</span>
                <Fragment set:html={dot(tg.hex, 7)} />
                {cb.top}
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>
</div>
