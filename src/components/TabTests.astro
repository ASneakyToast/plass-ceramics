---
---

<div id="tp-tests" class="tp">
  <div class="tip">Mark every combination you try. Notes save automatically to your browser.</div>
  <div class="grid" id="tgrid"></div>

  <div class="export-bar" style="margin-top:1.5rem;display:flex;gap:8px;align-items:center">
    <button id="export-btn" class="sbtn">Export my tests ↓</button>
    <label class="sbtn" style="cursor:pointer">
      Import tests
      <input type="file" id="import-input" accept=".json" style="display:none">
    </label>
  </div>
  <p id="import-msg" style="font-size:11px;color:var(--text-3);margin-top:6px;min-height:1em"></p>
</div>
